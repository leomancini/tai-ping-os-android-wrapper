# Copy this file to secrets.properties and fill in the real value.
# secrets.properties is gitignored; the key is embedded into the app at build time.
TAI_PING_API_KEY=tpk_xxx

# Optional: stable signing key so every build (on any machine) is signed the
# same way, letting new builds install over an existing one without wiping data.
# Leave these unset to use the default debug signing.
#
# Create the keystore once (keep the .jks file and these passwords safe — losing
# them means you can no longer update in place):
#   keytool -genkeypair -v -keystore tai-ping.jks -alias tai-ping \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Path is relative to the project root (where secrets.properties lives).
TAI_PING_KEYSTORE_FILE=tai-ping.jks
TAI_PING_KEYSTORE_PASSWORD=changeme
TAI_PING_KEY_ALIAS=tai-ping
TAI_PING_KEY_PASSWORD=changeme
